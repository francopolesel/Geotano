# ─── Geotano Environment Variables ─────────────────────────────────────────
# Copy to .env and fill in the values. Never commit .env to git.

# Database
DATABASE_URL=postgres://user:password@localhost:5432/geotano

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# CORS
CORS_ORIGIN=http://localhost:5173

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# REST Countries API
REST_COUNTRIES_API_KEY=
REST_COUNTRIES_URL=https://api.restcountries.com/v5
