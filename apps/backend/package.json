{
  "name": "@geotano/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx scripts/seed-countries.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@geotano/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.2.0",
    "socket.io": "^4.8.0",
    "jsonwebtoken": "^9.0.0",
    "neon-serverless": "^0.5.3",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
